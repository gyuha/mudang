[resource]
script = ExtResource("1")
id = &"stage_palace_wraith"
display_name = "6장 궁궐의 원귀"
duration = 480.0
intro_image_path = ""
intro_text = "왕실의 저주 굿이 팔도의 원혼을 깨웠다. 마지막 굿판. 전 적종이 총출동하는 궁궐 밤마당에서 궁중 원귀를 베어 새벽을 되찾아라."
objectives = [SubResource("Obj_kill_boss"), SubResource("Obj_survive")]
spawn_pool = [SubResource("SP_mob"), SubResource("SP_ghost"), SubResource("SP_dokkaebi"), SubResource("SP_changgwi"), SubResource("SP_mask"), SubResource("SP_plague")]
timeline = [SubResource("TL_200_rush"), SubResource("TL_260_boss")]
budget_base = 3.0
budget_growth_per_sec = 0.05
max_active_enemies = 500
soulfire_ratio = 0.6
unlock_requires = [&"stage_seonsucheong"]
recommended_roles = [&"tank", &"ranged", &"healer", &"aoe"]
unlock_companion = &""
reward = SubResource("Reward_palace")
hazards = [SubResource("HZ_court1"), SubResource("HZ_court2")]
