[resource]
script = ExtResource("1")
id = &"stage_seonsucheong"
display_name = "5장 성수청의 봉인"
duration = 450.0
intro_image_path = ""
intro_text = "폐지된 성수청 지하, 봉인진 셋을 순서대로 정화해야 한다. 깨어나는 원혼의 웨이브 속에서 봉인된 원귀와 맞선다. 역병의 근원이 왕실임을 안다."
objectives = [SubResource("Obj_survive"), SubResource("Obj_purify1"), SubResource("Obj_purify2"), SubResource("Obj_purify3")]
spawn_pool = [SubResource("SP_mob"), SubResource("SP_ghost"), SubResource("SP_mask"), SubResource("SP_changgwi")]
timeline = [SubResource("TL_300_boss")]
budget_base = 2.8
budget_growth_per_sec = 0.045
max_active_enemies = 500
soulfire_ratio = 0.6
unlock_requires = [&"stage_yangban_gut"]
recommended_roles = [&"aoe", &"healer", &"tank"]
unlock_companion = &""
reward = SubResource("Reward_seonsucheong")
hazards = [SubResource("HZ_seal")]
