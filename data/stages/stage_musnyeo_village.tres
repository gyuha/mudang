[resource]
script = ExtResource("1")
id = &"stage_musnyeo_village"
display_name = "2장 도성 밖 무녀촌"
duration = 420.0
intro_image_path = "res://assets/story/ch2_intro.png"
intro_text = "포졸이 무녀촌을 불사르려는 밤. 불길 속으로 요괴가 몰려든다. 초가집 셋을 지키고, 화랑 호위병과 함께 새벽을 맞아라."
objectives = [SubResource("Obj_survive"), SubResource("Obj_defend1"), SubResource("Obj_defend2"), SubResource("Obj_defend3")]
spawn_pool = [SubResource("SP_mob"), SubResource("SP_ghost"), SubResource("SP_dokkaebi")]
timeline = [SubResource("TL_120_dokkaebi"), SubResource("TL_240_dokkaebi2"), SubResource("TL_330_rush"), SubResource("TL_420_boss")]
budget_base = 2.5
budget_growth_per_sec = 0.04
max_active_enemies = 500
soulfire_ratio = 0.6
unlock_requires = [&"stage_hwalinseo"]
recommended_roles = [&"tank", &"ranged", &"healer"]
unlock_companion = &"hwarang"
reward = SubResource("Reward_village")
hazards = [SubResource("HZ_fire1"), SubResource("HZ_fire2")]
