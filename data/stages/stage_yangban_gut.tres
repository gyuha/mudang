[resource]
script = ExtResource("1")
id = &"stage_yangban_gut"
display_name = "4장 양반가의 은밀한 굿"
duration = 420.0
intro_image_path = ""
intro_text = "양반가의 굿이 수명을 빼앗는 저주 의식이었다. 탈귀의 저주와 역병귀의 독 장판 속에서 제단을 정화하고 새벽까지 버텨라."
objectives = [SubResource("Obj_survive"), SubResource("Obj_purify")]
spawn_pool = [SubResource("SP_mask"), SubResource("SP_plague")]
timeline = [SubResource("TL_240_boss")]
budget_base = 2.6
budget_growth_per_sec = 0.042
max_active_enemies = 500
soulfire_ratio = 0.6
unlock_requires = [&"stage_mountain_pass"]
recommended_roles = [&"healer", &"ranged"]
unlock_companion = &""
reward = SubResource("Reward_yangban")
hazards = [SubResource("HZ_poison1"), SubResource("HZ_poison2")]
